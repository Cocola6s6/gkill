{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "gkill",
  "version": "0.1.4",
  "identifier": "cn.gydev.gkill",
  "build": {
    "frontendDist": "ui/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "gkill — SkillHub Desktop",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
